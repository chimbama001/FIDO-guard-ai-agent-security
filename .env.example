# Copy to `.env.local` and fill in (loaded automatically by the CLI)

# OpenAI (recommended for live runs)
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: other providers are supported by LangChain — wire them in `src/nodes/` as needed
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

# Optional local Ollama (requires wiring ChatOllama in nodes — see README)
# OLLAMA_BASE_URL=http://localhost:11434
